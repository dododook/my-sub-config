{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "dns-direct",
        "type": "udp",
        "server": "223.5.5.5"
      },
      {
        "tag": "dns-proxy",
        "type": "https",
        "server": "8.8.8.8",
        "detour": "🔰 Proxy"
      },
      {
        "tag": "dns-fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15"
      }
    ],
    "rules": [
      { "outbound": "any", "action": "route", "server": "dns-direct" },
      { "clash_mode": "Direct", "action": "route", "server": "dns-direct" },
      { "clash_mode": "Global", "action": "route", "server": "dns-proxy" },
      {
        "query_type": ["A", "AAAA"],
        "action": "route",
        "server": "dns-fakeip"
      }
    ],
    "final": "dns-proxy",
    "strategy": "ipv4_only"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": ["172.18.0.1/24"],
      "auto_route": true,
      "strict_route": true,
      "stack": "system",
      "sniff": true,
      "sniff_override_destination": true
    },
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 7890
    }
  ],
  "outbounds": [
    {
      "tag": "🔰 Proxy",
      "type": "selector",
      "outbounds": ["♻️ Auto", "🎯 DIRECT", "👋 Select"]
    },
    {
      "tag": "♻️ Auto",
      "type": "urltest",
      "outbounds": ["{all}"],
      "url": "http://www.gstatic.com/generate_204",
      "interval": "10m"
    },
    {
      "tag": "👋 Select",
      "type": "selector",
      "outbounds": ["{all}"]
    },
    {
      "tag": "🤖 AI",
      "type": "selector",
      "outbounds": ["🔰 Proxy", "🎯 DIRECT"]
    },
    {
      "tag": "📺 YouTube",
      "type": "selector",
      "outbounds": ["🔰 Proxy", "🎯 DIRECT"]
    },
    {
      "tag": "🎯 DIRECT",
      "type": "direct"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "final": "🔰 Proxy",
    "rules": [
      { "protocol": "dns", "action": "hijack-dns" },
      { "port": 53, "action": "hijack-dns" },
      { "ip_is_private": true, "outbound": "🎯 DIRECT" },
      {
        "rule_set": ["geosite-openai", "geosite-ai"],
        "outbound": "🤖 AI"
      },
      {
        "rule_set": ["geosite-youtube"],
        "outbound": "📺 YouTube"
      },
      {
        "rule_set": ["geosite-cn", "geoip-cn"],
        "outbound": "🎯 DIRECT"
      }
    ]
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "store_fakeip": true
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "ui",
      "secret": ""
    }
  }
}
